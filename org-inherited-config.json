{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly"
  ],
  "automerge": true,
  "branchConcurrentLimit": 0,
  "dashboard": false,
  "lockFileMaintenance": {
    "enabled": true
  },
  "minimumReleaseAge": "3 days",
  "platformAutomerge": true,
  "postUpdateOptions": [
    "pnpmDedupe"
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ]
  }
}
